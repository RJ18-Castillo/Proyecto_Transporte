@{
    ViewData["Title"] = "Cambiar Clave";
    Layout = null;
}
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <title>TicoBus — Cambiar Clave</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
</head>
<body class="bg-light">
    <div class="container mt-5" style="max-width:420px">
        <div class="card shadow">
            <div class="card-body p-4">
                <h4 class="mb-4 text-center">🔑 Cambiar Clave</h4>

                @if (ViewBag.Error != null)
                {
                    <div class="alert alert-danger">@ViewBag.Error</div>
                }
                @if (ViewBag.Exito != null)
                {
                    <div class="alert alert-success">@ViewBag.Exito</div>
                }

                <form method="post">
                    <div class="mb-3">
                        <label class="form-label">Nombre de usuario</label>
                        <input name="nombreUsuario" class="form-control" required autofocus />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Clave actual</label>
                        <input name="claveActual" type="password" class="form-control" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Nueva clave</label>
                        <input name="nuevaClave" type="password" class="form-control" required />
                    </div>
                    <button class="btn btn-primary w-100">Actualizar clave</button>
                    <a href="/Auth/Login" class="d-block text-center mt-3 small">
                        ← Volver al login
                    </a>
                </form>
            </div>
        </div>
    </div>
</body>
</html>