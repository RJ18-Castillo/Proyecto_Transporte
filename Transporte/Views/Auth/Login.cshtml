@{
    ViewData["Title"] = "Iniciar Sesión";
    Layout = null;
}
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <title>TicoBus — Login</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
</head>
<body class="bg-light">
    <div class="container mt-5" style="max-width:420px">
        <div class="card shadow">
            <div class="card-body p-4">
                <h4 class="mb-4 text-center">🚌 TicoBus — Iniciar Sesión</h4>

                @if (ViewBag.Error != null)
                {
                    <div class="alert alert-danger">@ViewBag.Error</div>
                }

                <form method="post">
                    <div class="mb-3">
                        <label class="form-label">Nombre de usuario</label>
                        <input name="nombreUsuario" class="form-control" required autofocus />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Clave</label>
                        <input name="clave" type="password" class="form-control" required />
                    </div>
                    <button class="btn btn-primary w-100">Ingresar</button>
                    <a href="/Auth/CambioClave" class="d-block text-center mt-3 small">
                        ¿Olvidó su clave? Cambiar clave
                    </a>
                </form>
            </div>
        </div>
    </div>
</body>
</html>