@model Transporte.Model.Chofer

@{
    ViewData["Title"] = "Perfil de Chofer";
}

<div class="container mt-5">

    <div class="row justify-content-center">

        <div class="col-md-6">

            <div class="card shadow">

                <div class="card-header text-center">
                    <h3>Perfil del Chofer</h3>
                </div>

                <div class="card-body">

                    <div class="mb-3">
                        <label class="form-label fw-bold">Identificación</label>
                        <input type="text" class="form-control" value="@Model.Identificacion" readonly />
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-bold">Nombre</label>
                        <input type="text" class="form-control" value="@Model.Nombre" readonly />
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-bold">Apellidos</label>
                        <input type="text" class="form-control" value="@Model.Apellidos" readonly />
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-bold">Correo</label>
                        <input type="text" class="form-control" value="@Model.Correo" readonly />
                    </div>

                    <hr />

                    <div class="d-grid gap-2">

                        <a href="/Login/CambiarClave" class="btn btn-warning">
                            Cambiar contraseña
                        </a>

                        <a href="/Login/Logout" class="btn btn-danger">
                            Cerrar sesión
                        </a>

                    </div>

                </div>

            </div>

        </div>

    </div>

</div>