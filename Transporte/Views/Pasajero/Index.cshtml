            <th>Identificación</th>
            <th>Nombre</th>
            <th>Apellidos</th>
            <th>Correo</th>
            <th></th>
        </tr>
    </thead>

        <tbody>

          @foreach (var item in Model)
        {
             <tr>


            </tr>
        }


    </tbody>

</table>