@model IEnumerable<Transporte.Model.Pasajero>

@{
    ViewData["Title"] = "Pasajeros";
}

<div class="container mt-4">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>👥 Gestión de Pasajeros</h2>

        <a asp-controller="Pasajero" asp-action="Agregar" class="btn btn-primary">
            + Agregar Pasajero
        </a>
    </div>

    <form asp-controller="Pasajero" asp-action="Index" method="get" class="row mb-3">
        <div class="col-md-10">
            <input type="text"
                   name="filtro"
                   value="@ViewBag.Filtro"
                   class="form-control"
                   placeholder="Buscar por nombre o apellido..." />
        </div>

        <div class="col-md-2">
            <button type="submit" class="btn btn-secondary w-100">
                Buscar
            </button>
        </div>
    </form>

    <table class="table table-bordered table-hover">
        <thead class="table-dark">
            <tr>
                <th>Identificación</th>
                <th>Nombre completo</th>
                <th>Correo</th>
                <th style="width: 220px;">Acciones</th>
            </tr>
        </thead>

        <tbody>
            @if (Model != null && Model.Any())
            {
                foreach (var item in Model)
                {
                    <tr>
                        <td>@item.Cedula</td>
                        <td>@($"{item.Nombre1} {item.Nombre2} {item.Apellido1} {item.Apellido2}")</td>
                        <td>@item.CedulaNavigation?.Correo</td>
                        <td>
                            <a asp-controller="Pasajero"
                               asp-action="Editar"
                               asp-route-cedula="@item.Cedula"
                               class="btn btn-warning btn-sm">
                                Editar
                            </a>
                            <form asp-controller="Pasajero"
                                  asp-action="Eliminar"
                                  asp-route-cedula="@item.Cedula"
                                  method="post"
                                  style="display:inline;"
                                  onsubmit="return confirm('¿Eliminar este pasajero?');">
                                <button type="submit" class="btn btn-danger btn-sm">
                                    Eliminar
                                </button>
                            </form>
                        </td>
                    </tr>
                }
            }
            else
            {
                <tr>
                    <td colspan="4" class="text-center text-muted">
                        No hay pasajeros registrados.
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>