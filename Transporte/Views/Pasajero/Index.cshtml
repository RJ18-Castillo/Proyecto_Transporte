@model List<Transporte.Model.Pasajero>

@{
    ViewData["Title"] = "Pasajeros";
}

<h1>Pasajeros</h1>

<form method="get">

    <input type="text"
           name="filtro"
           value="@ViewBag.Filtro"
           placeholder="Buscar por nombre" />

    <button type="submit">Buscar</button>

    <a asp-action="Create">Nuevo Pasajero</a>

</form>

<br />

<table class="table">

    <thead>
