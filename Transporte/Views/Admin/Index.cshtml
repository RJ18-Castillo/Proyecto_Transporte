@{
    ViewData["Title"] = "Panel Administrador";
}

<div class="container mt-4">
    <h4 class="mb-1">👋 Bienvenido, @Context.Session.GetString("NombreUsuario")</h4>
    <p class="text-muted mb-4">Panel de Administración — TicoBus</p>

    <div class="row g-3">
        <div class="col-md-4">
            <div class="card shadow-sm h-100">
                <div class="card-body">
                    <h5 class="card-title">👷 Choferes</h5>
                    <p class="card-text text-muted">Registrar y gestionar los choferes del sistema.</p>
                    <a href="/Choferes/Index" class="btn btn-primary">Ir al módulo</a>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card shadow-sm h-100">
                <div class="card-body">
                    <h5 class="card-title">🗺️ Rutas</h5>
                    <p class="card-text text-muted">Gestionar las rutas disponibles.</p>
                    <a href="/Rutas" class="btn btn-primary">Ir al módulo</a>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card shadow-sm h-100">
                <div class="card-body">
                    <h5 class="card-title">🚌 Unidades</h5>
                    <p class="card-text text-muted">Gestionar los autobuses disponibles.</p>
                    <a href="/Unidades" class="btn btn-primary">Ir al módulo</a>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card shadow-sm h-100">
                <div class="card-body">
                    <h5 class="card-title">🚗 Viajes</h5>
                    <p class="card-text text-muted">Programar y gestionar viajes.</p>
                    <a href="/Viajes" class="btn btn-primary">Ir al módulo</a>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card shadow-sm h-100">
                <div class="card-body">
                    <h5 class="card-title">▶️ Viajes en Curso</h5>
                    <p class="card-text text-muted">Gestionar reservas de viajes activos.</p>
                    <a href="/ViajesEnCurso" class="btn btn-primary">Ir al módulo</a>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card shadow-sm h-100">
                <div class="card-body">
                    <h5 class="card-title">❌ Viajes Cancelados</h5>
                    <p class="card-text text-muted">Consultar historial de viajes cancelados.</p>
                    <a href="/ViajesCancelados" class="btn btn-primary">Ir al módulo</a>
                </div>
            </div>
        </div>
    </div>

    <div class="mt-4">
        <a href="/Auth/Logout" class="btn btn-outline-danger">Cerrar sesión</a>
    </div>
</div>