@model Transporte.Model.Ruta

@{
    ViewData["Title"] = "Editar Ruta";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-6">

            <h2 class="mb-4">
                ✏️ Editar Ruta
            </h2>

            @if (ViewBag.Error != null)
            {
                <div class="alert alert-danger">
                    @ViewBag.Error
                </div>
            }

            <form asp-controller="Rutas" asp-action="Editar" method="post">

                <input type="hidden" name="id" value="@Model.Id" />

                <div class="mb-3">
                    <label class="form-label">Nombre <span class="text-danger">*</span></label>
                    <input name="nombre" value="@Model.Nombre" required class="form-control" />
                </div>

                <div class="mb-3">
                    <label class="form-label">Origen <span class="text-danger">*</span></label>
                    <input name="origen" value="@Model.Origen" required class="form-control" />
                </div>

                <div class="mb-3">
                    <label class="form-label">Destino <span class="text-danger">*</span></label>
                    <input name="destino" value="@Model.Destino" required class="form-control" />
                </div>

                <div class="mb-3">
                    <label class="form-label">Duración estimada (hh:mm) <span class="text-danger">*</span></label>
                    <input name="duracionEstimada"
                           value="@Model.DuracionEstimada.ToString(@"hh\:mm")"
                           required
                           pattern="^([0-9]{1,2}):[0-5][0-9]$"
                           placeholder="Ejemplo: 02:30"
                           class="form-control" />
                </div>

                <div class="mb-3">
                    <label class="form-label">Precio base por pasajero <span class="text-danger">*</span></label>
                    <input name="precioBase"
                           type="number"
                           step="0.01"
                           min="0"
                           value="@Model.PrecioBase"
                           required
                           class="form-control" />
                </div>

                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-primary">
                        Guardar cambios
                    </button>

                    <a asp-controller="Rutas" asp-action="Index" class="btn btn-secondary">
                        Cancelar
                    </a>
                </div>

            </form>

        </div>
    </div>
</div>