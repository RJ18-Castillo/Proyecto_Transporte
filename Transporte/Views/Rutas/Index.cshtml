@model IEnumerable<Transporte.Model.Ruta>

@{
    ViewData["Title"] = "Rutas";
}

<div class="container mt-4">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>🗺️ Gestión de Rutas</h2>

        <a asp-controller="Rutas" asp-action="Agregar" class="btn btn-primary">
            + Agregar Ruta
        </a>
    </div>

    @if (TempData["Exito"] != null)
    {
        <div class="alert alert-success">
            @TempData["Exito"]
        </div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger">
            @TempData["Error"]
        </div>
    }

    <form asp-controller="Rutas" asp-action="Index" method="get" class="row mb-3">
        <div class="col-md-10">
            <input type="text"
                   name="filtro"
                   value="@ViewBag.Filtro"
                   class="form-control"
                   placeholder="Buscar por nombre o destino..." />
        </div>

        <div class="col-md-2">
            <button type="submit" class="btn btn-secondary w-100">
                Buscar
            </button>
        </div>
    </form>

    <table class="table table-bordered table-hover">
        <thead class="table-dark">
            <tr>
                <th>Nombre</th>
                <th>Origen</th>
                <th>Destino</th>
                <th>Duración estimada (hh:mm)</th>
                <th>Precio base</th>
                <th style="width: 180px;">Acciones</th>
            </tr>
        </thead>

        <tbody>
            @if (Model != null && Model.Any())
            {
                foreach (var item in Model)
                {
                    <tr>
                        <td>@item.Nombre</td>
                        <td>@item.Origen</td>
                        <td>@item.Destino</td>
                        <td>@item.DuracionEstimada.ToString(@"hh\:mm")</td>
                        <td>₡@item.PrecioBase.ToString("N2")</td>
                        <td>
                            <a asp-controller="Rutas"
                               asp-action="Editar"
                               asp-route-id="@item.Id"
                               class="btn btn-warning btn-sm">
                                Editar
                            </a>
                            <form asp-controller="Rutas"
                                  asp-action="Eliminar"
                                  asp-route-id="@item.Id"
                                  method="post"
                                  style="display:inline;"
                                  onsubmit="return confirm('¿Eliminar esta ruta?');">
                                <button type="submit" class="btn btn-danger btn-sm">
                                    Eliminar
                                </button>
                            </form>
                        </td>
                    </tr>
                }
            }
            else
            {
                <tr>
                    <td colspan="6" class="text-center text-muted">
                        No hay rutas registradas.
                    </td>
                </tr>
            }
        </tbody>
    </table>

</div>