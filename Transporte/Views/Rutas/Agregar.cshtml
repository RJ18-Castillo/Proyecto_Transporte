@{
    ViewData["Title"] = "Agregar Ruta";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-6">

            <h2 class="mb-4">
                🗺️ Agregar Ruta
            </h2>

            @if (ViewBag.Error != null)
            {
                <div class="alert alert-danger">
                    @ViewBag.Error
                </div>
            }

            <form asp-controller="Rutas" asp-action="Agregar" method="post">

                <div class="mb-3">
                    <label class="form-label">Nombre <span class="text-danger">*</span></label>
                    <input name="nombre" required class="form-control" />
                </div>

                <div class="mb-3">
                    <label class="form-label">Origen <span class="text-danger">*</span></label>
                    <input name="origen" required class="form-control" />
                </div>

                <div class="mb-3">
                    <label class="form-label">Destino <span class="text-danger">*</span></label>
                    <input name="destino" required class="form-control" />
                </div>

                <div class="mb-3">
                    <label class="form-label">Duración estimada (hh:mm) <span class="text-danger">*</span></label>
                    <input name="duracionEstimada"
                           required
                           pattern="^([0-9]{1,2}):[0-5][0-9]$"
                           placeholder="Ejemplo: 02:30"
                           class="form-control" />
                </div>

                <div class="mb-3">
                    <label class="form-label">Precio base por pasajero <span class="text-danger">*</span></label>
                    <input name="precioBase"
                           type="number"
                           step="0.01"
                           min="0"
                           required
                           class="form-control" />
                </div>

                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-primary">
                        Guardar
                    </button>

                    <a asp-controller="Rutas" asp-action="Index" class="btn btn-secondary">
                        Cancelar
                    </a>
                </div>

            </form>

        </div>
    </div>
</div>